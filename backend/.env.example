# 소담(SODAM) 백엔드 환경변수 템플릿
# 사용법: cp .env.example .env 후 실제 값으로 채우기
# 주의: 실제 시크릿은 절대 커밋 금지 (.env는 .gitignore에 포함됨)

# =============================================================================
# 데이터베이스
# =============================================================================
DB_URL=jdbc:mysql://localhost:3306/sodam?serverTimezone=Asia/Seoul&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=root
DB_PASSWORD=__REPLACE_ME__
DB_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# =============================================================================
# JWT
# =============================================================================
# 운영: 32바이트 이상 랜덤 문자열 (openssl rand -base64 48)
JWT_SECRET=__REPLACE_ME_WITH_32_BYTES_RANDOM__
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# =============================================================================
# Kakao OAuth (https://developers.kakao.com)
# =============================================================================
KAKAO_CLIENT_ID=__REPLACE_ME__
KAKAO_CLIENT_SECRET=__REPLACE_ME__
KAKAO_REDIRECT_URI=http://localhost:8080/kakao/auth/proc

# =============================================================================
# Redis
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2000
REDIS_DATABASE=0
REDIS_CACHE_DATABASE=1
REDIS_CACHE_TTL=3600

# =============================================================================
# 애플리케이션
# =============================================================================
SPRING_PROFILES_ACTIVE=local
APP_NAME=sodam
APP_VERSION=1.0.0
SERVER_PORT=8080

# =============================================================================
# 로깅
# =============================================================================
LOG_LEVEL=INFO
ROOT_LOG_LEVEL=WARN
SECURITY_LOG_LEVEL=WARN
SQL_LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/sodam.log

# =============================================================================
# JPA
# =============================================================================
DDL_AUTO=update
SHOW_SQL=false
FORMAT_SQL=false

# =============================================================================
# 비즈니스 룰
# =============================================================================
STORE_DEFAULT_RADIUS=100
STORE_MAX_RADIUS=1000
ATTENDANCE_CHECK_RADIUS=50
ATTENDANCE_LATE_THRESHOLD_MINUTES=10
SALARY_OVERTIME_RATE=1.5
SALARY_NIGHT_SHIFT_RATE=1.5

# =============================================================================
# 외부 API
# =============================================================================
# 카카오 지도 (Geocoding)
MAP_API_KEY=__REPLACE_ME__
MAP_API_URL=https://dapi.kakao.com

# 토스페이먼츠 (정기결제) - C-1 컨펌 후 입력
TOSS_CLIENT_KEY=__REPLACE_ME_TEST_KEY__
TOSS_SECRET_KEY=__REPLACE_ME_TEST_KEY__
TOSS_BASE_URL=https://api.tosspayments.com
TOSS_WEBHOOK_SECRET=__REPLACE_ME__

# FCM (푸시) - C-2 컨펌 후 입력
FCM_PROJECT_ID=__REPLACE_ME__
FCM_CREDENTIALS_PATH=./secrets/firebase-service-account.json

# Sentry - C-3 컨펌 후 입력
SENTRY_DSN=__REPLACE_ME__
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# 파일 업로드
# =============================================================================
FILE_UPLOAD_PATH=./uploads
FILE_MAX_SIZE=10MB
FILE_MAX_REQUEST_SIZE=50MB
ALLOWED_FILE_EXTENSIONS=jpg,jpeg,png,pdf,xlsx,xls

# =============================================================================
# 보안
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_SPECIAL_CHAR=true
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_MAX_ATTEMPTS=5

API_RATE_LIMIT_REQUESTS_PER_MINUTE=60
API_RATE_LIMIT_ENABLED=true

# =============================================================================
# 모니터링
# =============================================================================
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when_authorized
METRICS_EXPORT_PROMETHEUS_ENABLED=true

# =============================================================================
# 개발 플래그
# =============================================================================
DEV_MODE=true
DEBUG_MODE=false
SWAGGER_ENABLED=true
