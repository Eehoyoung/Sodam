# =============================================================================
# 소담 — 운영 프로필 템플릿
# 사용: cp application-prod.yml.example application-prod.yml 후 실제 값 입력
# application-prod.yml 은 .gitignore 에 포함됨
# =============================================================================

spring:
  datasource:
    url: ${DB_URL}
    driver-class-name: com.mysql.cj.jdbc.Driver
    username: ${DB_USERNAME}
    password: ${DB_PASSWORD}
    hikari:
      maximum-pool-size: 20
      minimum-idle: 5
      connection-timeout: 30000
      idle-timeout: 600000
      max-lifetime: 1800000

  # Flyway 가 스키마를 관리하고(ddl-auto=validate 로 엔티티-스키마 정합만 검증).
  #  - 신규 DB: V1__baseline 으로 전체 스키마 생성 → V2+ 순차 적용.
  #  - 기존 운영 DB(이미 ddl-auto 로 생성된 경우): baseline-on-migrate=true 로 V1 은 마커만,
  #    V2+ 부터 적용. baseline-version 은 기존 스키마가 V1 상태임을 의미.
  #  ⚠️ 첫 적용 전 DB 백업 필수. 마이그레이션 실행은 운영 배포 절차(인간 승인) 하에 진행.
  flyway:
    enabled: true
    baseline-on-migrate: true
    baseline-version: 1
    validate-on-migrate: true

  jpa:
    hibernate:
      ddl-auto: validate
    properties:
      hibernate:
        format_sql: false
        cache:
          use_second_level_cache: true
          use_query_cache: true
    show-sql: false

  data:
    redis:
      host: ${REDIS_HOST}
      port: ${REDIS_PORT:6379}
      password: ${REDIS_PASSWORD}
      timeout: 3000ms

  security:
    oauth2:
      client:
        registration:
          kakao:
            client-id: ${KAKAO_CLIENT_ID}
            client-secret: ${KAKAO_CLIENT_SECRET}
            redirect-uri: https://sodam-api.com/kakao/auth/proc

jwt:
  secret: ${JWT_SECRET}
  token-validity-in-seconds: 3600
  refresh-token-validity-in-days: 7
  cookie-name: sodam_jwt
  cookie-max-age: 3600

sodam:
  # PIPA §29: 개인정보(휴대폰 등) 컬럼 암호화 키.
  #  - Base64(16/24/32 byte) 또는 임의 문자열(SHA-256 으로 32byte 파생) 허용. 32byte(AES-256) 권장.
  #  - 미설정 시 평문 모드로 폴백(dev/test). 운영에서는 반드시 설정.
  #  - 키는 AWS Secrets Manager 로 주입. 절대 커밋 금지.
  #  ⚠️ 키 로테이션 시 구 키로 암호화된 값은 복호화 실패 → 평문 폴백되어 가독 불가.
  #     로테이션 전 백필 배치로 재암호화 필요.
  security:
    pii:
      encryption-key: ${SODAM_PII_ENCRYPTION_KEY}
      # 블라인드 인덱스(§2.6) HMAC 페퍼 — encryption-key 와 반드시 별도 시크릿(키 분리).
      # business_number 처럼 암호화(비결정적)된 컬럼도 이 해시로 동등검색·중복 가입 방지가 가능해진다.
      # 미설정 시 부팅 거부(fail-fast, dev/test 는 고정 폴백 페퍼로 대체).
      search-pepper: ${SODAM_PII_SEARCH_PEPPER}
      # Phase 0 PII 핫픽스 백필(1회성) — 기본 false. 배포 후 한 번만 true로 켜고 로그에서
      # "N건 처리" 확인되면 즉시 false로 되돌릴 것(매 재기동마다 반복 실행되지 않도록).
      backfill-business-number-hash: false
  retention:
    purge:
      # Phase 6 보존기간 파기 배치(§2.2(c)) — scan(스케줄 등록)은 항상 실행되지만 실제 파기(삭제)는
      # 기본 비활성. 스테이징에서 유예·고지 동작을 먼저 검증한 뒤에만 true로 전환할 것 — 되돌릴 수 없다.
      execute-enabled: false
  integration:
    toss:
      mode: live
      client-key: ${TOSS_CLIENT_KEY}
      secret-key: ${TOSS_SECRET_KEY}
      base-url: https://api.tosspayments.com
      webhook-secret: ${TOSS_WEBHOOK_SECRET}
    fcm:
      mode: live
      project-id: ${FCM_PROJECT_ID}
      credentials-path: ${FCM_CREDENTIALS_PATH}
    sentry:
      mode: live
      dsn: ${SENTRY_DSN}
      environment: prod
      traces-sample-rate: 0.1
    kakao:
      mode: live
      base-url: https://dapi.kakao.com
      rest-api-key: ${KAKAO_REST_API_KEY}
    channel-talk:
      mode: live
      plugin-key: ${CHANNEL_TALK_PLUGIN_KEY}
    # 세무사 인건비 내역서 송부·비밀번호 재설정 메일 — 발신 도메인 DKIM/SPF 설정 후 live 전환
    mail:
      mode: live
      host: ${SODAM_MAIL_HOST}
      port: ${SODAM_MAIL_PORT:587}
      username: ${SODAM_MAIL_USERNAME}
      password: ${SODAM_MAIL_PASSWORD}
      from: ${SODAM_MAIL_FROM}
      starttls: true

logging:
  level:
    root: WARN
    com.rich.sodam: INFO

management:
  endpoints:
    web:
      exposure:
        include: health,info,metrics,prometheus
  endpoint:
    health:
      show-details: never

server:
  forward-headers-strategy: native
  tomcat:
    max-http-form-post-size: 10MB
