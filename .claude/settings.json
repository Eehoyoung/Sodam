{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(./gradlew test*)",
      "Bash(./gradlew build*)",
      "Bash(./gradlew bootRun*)",
      "Bash(./gradlew clean*)",
      "Bash(npm install*)",
      "Bash(npm run lint*)",
      "Bash(npm run test*)",
      "Bash(npm run start*)",
      "Bash(npm run android*)",
      "Bash(npm run build:android*)",
      "Bash(npm run metro-reset*)",
      "Bash(npm run gradle-clean*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git stash*)",
      "Bash(git restore*)",
      "Bash(git config --get*)",
      "Bash(ls*)",
      "Bash(node -v*)",
      "Bash(java -version*)",
      "Bash(java --version*)",
      "Bash(./gradlew --version*)",
      "Bash(npx tsc*)",
      "Bash(npx jest*)",
      "Bash(npx eslint*)",
      "Bash(git push origin master*)",
      "Bash(git push origin main*)",
      "Bash(git push --force-with-lease origin master*)",
      "Bash(git push --force origin master*)",
      "Bash(rm -rf .gradle*)",
      "Bash(rm -rf .idea*)",
      "Bash(rm -rf .junie*)",
      "Bash(rm -rf build*)",
      "Bash(rm -rf logs*)",
      "Bash(rm -rf out*)",
      "Bash(rm -rf docs*)",
      "Bash(rm -rf src*)",
      "Bash(rm -rf .git.backup*)",
      "Bash(rm -rf .git*)",
      "Bash(rm -rf frontend/.git*)"
    ],
    "deny": [
      "Bash(git push --force origin main*)",
      "Bash(git push -f origin main*)",
      "Bash(git reset --hard*)",
      "Bash(git branch -D*)",
      "Bash(git clean -f*)",
      "Bash(git commit --no-verify*)",
      "Bash(Remove-Item -Recurse -Force C:\\*)",
      "Bash(npm publish*)",
      "Bash(./gradlew publish*)",
      "Bash(aws s3 rm*)",
      "Bash(aws rds delete*)",
      "Bash(aws ec2 terminate*)",
      "Bash(mysql*-e DROP*)",
      "Bash(mysql*-e TRUNCATE*)",
      "Bash(curl*api.tosspayments.com*)",
      "Bash(curl*fcm.googleapis.com*)"
    ]
  },
  "env": {
    "SODAM_ENV": "local"
  }
}
