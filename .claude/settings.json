{
  "extraKnownMarketplaces": {
    "claude-for-legal": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-for-legal"
      }
    }
  },
  "enabledPlugins": {
    "employment-legal@claude-for-legal": true,
    "privacy-legal@claude-for-legal": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-secrets.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "C:\\Users\\LeeHoYoung\\.local\\bin\\graphify.EXE hook-guard search"
          }
        ]
      },
      {
        "matcher": "Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "C:\\Users\\LeeHoYoung\\.local\\bin\\graphify.EXE hook-guard read"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/format-on-save.sh\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(./gradlew test:*)",
      "Bash(./gradlew build:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run test:unit:*)",
      "Bash(npm test:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose ps:*)",
      "Bash(adb devices:*)",
      "Bash(adb shell uiautomator dump:*)",
      "Bash(adb exec-out screencap:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/.env.*)"
    ]
  }
}