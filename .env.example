# =============================================================================
# 소담(SODAM) Monorepo — 단일 .env 템플릿
# =============================================================================
# 사용법:
#   1) cp .env.example .env
#   2) 비밀번호/시크릿을 실제 값으로 수정
#   3) docker compose up -d --build   (Docker 풀스택)
#      또는 cd backend && ./gradlew bootRun --args='--spring.profiles.active=dev'   (로컬 H2)
#
# 작동 원리:
#   - Docker: docker-compose.yml 이 자동으로 이 .env 를 service environment 로 전달
#   - 로컬 gradle: backend/application.yml 의 spring.config.import 가 ../env 를 fallback 로드
#     (backend/.env 가 있으면 그게 우선, 없으면 루트 .env)
#
# 주의: .env 는 .gitignore 처리. 절대 커밋 금지.
# =============================================================================


# ─── 호스트 포트 매핑 (docker compose 전용) ─────────────────────────────
# 다른 프로젝트(Docker)와 충돌 회피용. 컨테이너 내부는 모두 표준 포트.
SODAM_BE_PORT=7070
SODAM_DB_PORT=13306
SODAM_REDIS_PORT=16379
SODAM_ADMINER_PORT=18080


# ─── Spring 프로필 ───────────────────────────────────────────────────────
# dev: H2 in-memory + DevSeed 자동 + Mock 외부 서비스 (로컬 개발)
# prod: MySQL + Redis 실제 연결 (Docker compose default)
SPRING_PROFILES_ACTIVE=prod


# ─── DB (prod 프로필에서 사용) ──────────────────────────────────────────
# 운영: 강력한 무작위 비밀번호. 예: openssl rand -base64 32
SODAM_DB_ROOT_PASSWORD=change-me-root-strong-password
SODAM_DB_PASSWORD=change-me-app-strong-password

# Docker network 내부 호스트 (compose 자동 해석)
DB_URL=jdbc:mysql://sodam-mysql:3306/sodam?serverTimezone=Asia/Seoul&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=sodam
DB_PASSWORD=${SODAM_DB_PASSWORD}
DB_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver


# ─── Redis ──────────────────────────────────────────────────────────────
REDIS_HOST=sodam-redis
REDIS_PORT=6379


# ─── JWT (HS384) ────────────────────────────────────────────────────────
# 운영: 32바이트(=256비트) 이상의 base64 무작위. 예: openssl rand -base64 48
SODAM_JWT_SECRET=change-me-32-bytes-minimum-secret-key-for-jwt-hs384
JWT_SECRET=${SODAM_JWT_SECRET}
# 단위 명시 — yaml token-validity-in-seconds / refresh-token-validity-in-days 와 1:1
JWT_TOKEN_VALIDITY_SECONDS=3600   # access token: 1시간 (초)
JWT_REFRESH_VALIDITY_DAYS=7       # refresh token: 7일


# ─── Hibernate (운영은 validate 또는 none 권장) ────────────────────────
# 첫 부팅 시 update 로 스키마 자동 생성 → 안정화되면 validate 로 전환
SPRING_JPA_HIBERNATE_DDL_AUTO=update


# ─── Actuator 노출 (Docker healthcheck 용) ──────────────────────────────
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when-authorized


# ─── 외부 통합 모드 (mock | live | off) ─────────────────────────────────
# Phase 1 (출시 전): 전부 mock 권장. live 키 발급 후 단계 전환.
# ⚠️ 변수명은 application.yml 이 실제로 읽는 SODAM_INTEGRATION_*_MODE 여야 한다(이전 SODAM_TOSS_MODE 는 무효).
SODAM_INTEGRATION_TOSS_MODE=mock
SODAM_INTEGRATION_FCM_MODE=mock
SODAM_INTEGRATION_SENTRY_MODE=off
SODAM_INTEGRATION_KAKAO_MODE=mock
SODAM_INTEGRATION_CHANNEL_MODE=off


# ─── 카카오 OAuth (live 모드 시 필수) ──────────────────────────────────
# https://developers.kakao.com 앱 등록 후 발급
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:7070/kakao/auth/proc


# ─── 토스페이먼츠 (결제 라이브 전환 — 키만 넣으면 작동) ──────────────────
# https://developers.tosspayments.com — test_* 는 샌드박스 키
# [결제 켜는 법] 아래 3개 키를 실키로 바꾸고 SODAM_INTEGRATION_TOSS_MODE=live 로 전환하면
#   ① 정기결제(빌링) ② 단건결제(세무 패키지 confirm) ③ 웹훅 동기화 가 모두 동작한다.
#   - mode=live 인데 키가 비었거나 test_* 면 부팅이 실패한다(LiveTossBillingClient 가 차단).
#   - FE 도 SODAM_TOSS_CLIENT_KEY 를 실키(live_ck_*)로 넣어야 결제창이 열린다(isTossLive()).
TOSS_CLIENT_KEY=test_ck_dev
TOSS_SECRET_KEY=test_sk_dev
# 보안: 비어있으면 webhook 모두 거부 (TossWebhookController 자체 보호). 토스 콘솔의 웹훅 시크릿.
TOSS_WEBHOOK_SECRET=

# ─── Flyway (운영 스키마 마이그레이션) ─────────────────────────────────
# 운영 전환 시 true 로. V1~V11(구독 티어·청구주기·세무주문) 적용. ⚠️ 실행 전 백업/검토 필수.
FLYWAY_ENABLED=false


# ─── FCM (live 모드 시 필수) ────────────────────────────────────────────
# Firebase Console > 서비스 계정 > 새 비공개 키 JSON 을 secrets/ 에 volume 마운트
FCM_PROJECT_ID=sodam-prod
FCM_CREDENTIALS_PATH=/app/secrets/fcm-service-account.json


# ─── Sentry (live 모드 시 필수) ─────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=prod
SENTRY_TRACES_SAMPLE_RATE=0.1


# ─── 채널톡 (옵션) ──────────────────────────────────────────────────────
CHANNEL_TALK_PLUGIN_KEY=


# ─── 국세청 사업자등록번호 (옵션 — 사장 가입 자동 검증) ─────────────
# https://www.data.go.kr 사업자등록 진위확인 API 신청
NTS_API_KEY=


# ─── 영수증 OCR (옵션 — 매입장부 자동인식) ──────────────────────────────
# 비워두면 NoopReceiptOcrClient(빈 초안) 동작 → 외부호출 0, 비용 0, 사장 수기입력.
# 값을 채우면 receiptOcrProvider(ClovaReceiptOcrClient) 빈이 Noop 을 대체해 자동 인식.
# 네이버 CLOVA OCR Receipt: https://www.ncloud.com/product/aiService/ocr 에서 도메인 생성 후 Invoke URL/Secret 발급.
SODAM_OCR_PROVIDER=
SODAM_OCR_API_URL=
SODAM_OCR_SECRET_KEY=


# ─── CORS (운영 도메인 추가 시) ─────────────────────────────────────────
# 콤마 구분. 개발용 origin 은 WebConfig 에 이미 등록됨.
# 예: SODAM_CORS_ALLOWED_ORIGINS=https://sodam.app,https://www.sodam.app
SODAM_CORS_ALLOWED_ORIGINS=


# =============================================================================
# 고급 — 보통 건드릴 필요 없음 (application.yml default 사용)
# =============================================================================

# JVM 옵션 override
# JAVA_OPTS=-XX:+UseG1GC -XX:MaxRAMPercentage=75

# 로그 레벨 (TRACE | DEBUG | INFO | WARN | ERROR)
# LOGGING_LEVEL_COM_RICH_SODAM=INFO
# LOGGING_LEVEL_ROOT=INFO

# 비즈니스 정책
# STORE_DEFAULT_RADIUS=100
# ATTENDANCE_CHECK_RADIUS=50


# =============================================================================
# FCM 푸시 (Frontend) — key-ready. 키 주입 전에는 graceful fallback(no-op)로 동작.
# =============================================================================
# FE 코드는 @react-native-firebase/messaging 를 optional-require 로 lazy-load 하므로
# 아래 키/모듈이 없어도 크래시 없이 빌드/실행된다. 키 주입 시 자동 활성화.
#
# 활성화 절차(시크릿이므로 google-services.json·plist 는 절대 커밋 금지):
#   1) Firebase 콘솔에서 앱 등록 → google-services.json 다운로드
#      → frontend/android/app/google-services.json 배치
#   2) (iOS) GoogleService-Info.plist → frontend/ios/ 배치 후 `cd frontend/ios && pod install`
#   3) `cd frontend && npm install`  (package.json 에 firebase app·messaging 선언됨)
#   4) android/iOS rebuild → FCM 토큰 등록·푸시 수신 자동 동작
# (android build.gradle classpath + app/build.gradle 의 google-services 플러그인은
#  google-services.json 존재 시에만 적용되도록 가드되어 있음.)

# ── PII 암호화 (PIPA §29) ─────────────────────────────────────
# phone·사업자등록번호 등 개인정보 컬럼을 AES-256-GCM 으로 암호화 저장.
# 운영 필수: 랜덤 32바이트 Base64 키 주입(미설정 시 prod 부팅 거부). 생성 예:
#   openssl rand -base64 32
SODAM_PII_KEY=
