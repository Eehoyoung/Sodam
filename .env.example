# =============================================================================
# 소담(SODAM) docker-compose 환경변수 템플릿
# 사용법:
#   1) cp .env.example .env
#   2) 비밀번호/시크릿을 실제 값으로 수정
#   3) docker compose up -d --build
# 주의: .env 는 .gitignore 처리됨. 절대 커밋 금지.
# =============================================================================


# ─── 호스트 포트 매핑 ──────────────────────────────────────────────────────
# 다른 프로젝트(Docker)와 충돌 회피용. 컨테이너 내부는 모두 표준 포트 그대로.
SODAM_BE_PORT=7070
SODAM_DB_PORT=13306
SODAM_REDIS_PORT=16379
SODAM_ADMINER_PORT=18080


# ─── DB (MySQL 8) ─────────────────────────────────────────────────────────
# 반드시 운영에서는 강력한 무작위 비밀번호로 교체. 예: openssl rand -base64 32
SODAM_DB_ROOT_PASSWORD=change-me-root-strong-password
SODAM_DB_PASSWORD=change-me-app-strong-password


# ─── JWT (HS384) ──────────────────────────────────────────────────────────
# 32바이트(=256비트) 이상의 base64 무작위 시크릿. 예: openssl rand -base64 48
SODAM_JWT_SECRET=change-me-32-bytes-minimum-secret-key-for-jwt-hs384


# ─── 외부 통합 mode 토글 (mock | live | off) ─────────────────────────────
# Phase 1 (출시 전): 전부 mock 권장. live 키 발급 후 단계적으로 전환.
SODAM_TOSS_MODE=mock
SODAM_FCM_MODE=mock
SODAM_SENTRY_MODE=off
SODAM_KAKAO_MODE=mock


# ─── 카카오 OAuth (live 모드 시 필수) ────────────────────────────────────
# https://developers.kakao.com 에서 앱 등록 후 발급
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=


# ─── 토스페이먼츠 (live 모드 시 필수) ────────────────────────────────────
# https://developers.tosspayments.com 에서 발급. test_ck_* / test_sk_* 는 샌드박스 키.
TOSS_CLIENT_KEY=test_ck_dev
TOSS_SECRET_KEY=test_sk_dev
TOSS_WEBHOOK_SECRET=change-me-webhook-secret


# ─── FCM (live 모드 시 필수) ─────────────────────────────────────────────
# Firebase Console > 프로젝트 설정 > 서비스 계정 > 새 비공개 키
# 서비스 계정 JSON 파일을 /app/secrets/ 에 volume 마운트로 주입 권장.
FCM_PROJECT_ID=sodam-prod
FCM_CREDENTIALS_PATH=/app/secrets/fcm-service-account.json


# ─── Sentry (live 모드 시 필수) ──────────────────────────────────────────
# https://sentry.io 프로젝트 생성 후 DSN 복사
SENTRY_DSN=
SENTRY_ENVIRONMENT=prod
SENTRY_TRACES_SAMPLE_RATE=0.1


# ─── 채널톡 (옵션 — Phase 2 고객 응대 채널) ────────────────────────────
CHANNEL_TALK_PLUGIN_KEY=


# ─── 국세청 사업자등록번호 조회 (옵션 — 사장 가입 시 자동 검증) ──────
# https://www.data.go.kr 사업자등록 진위확인 API 신청
NTS_API_KEY=


# =============================================================================
# 고급 / 디버그용 — 보통 건드릴 필요 없음
# =============================================================================

# Spring 프로필 (dev: H2 in-memory, prod: MySQL)
# 기본 prod. dev 로 바꾸면 MySQL 컨테이너 불필요.
# SPRING_PROFILES_ACTIVE=prod

# Hibernate 스키마 자동 관리 (validate | update | create | create-drop | none)
# 운영: validate 권장 (Flyway/Liquibase 도입 전). 개발: update.
# SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Actuator 엔드포인트 노출 (콤마 구분)
# MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info

# JVM 옵션 override
# JAVA_OPTS=-XX:+UseG1GC -XX:MaxRAMPercentage=75 -Xss512k

# 로그 레벨 (TRACE | DEBUG | INFO | WARN | ERROR)
# LOGGING_LEVEL_COM_RICH_SODAM=INFO
# LOGGING_LEVEL_ROOT=INFO
