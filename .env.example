# =============================================================================
# 소담 docker-compose 환경변수 템플릿
# 사용법:  cp .env.example .env  → 실제 값으로 수정 →  docker compose up -d
# =============================================================================

# ---------- 호스트 포트 매핑 (다른 프로젝트 충돌 회피) ----------
SODAM_BE_PORT=7070
SODAM_DB_PORT=13306
SODAM_REDIS_PORT=16379
SODAM_ADMINER_PORT=18080

# ---------- DB ----------
SODAM_DB_ROOT_PASSWORD=change-me-root-strong-password
SODAM_DB_PASSWORD=change-me-app-strong-password

# ---------- JWT (운영은 32바이트+ 랜덤. openssl rand -base64 48) ----------
SODAM_JWT_SECRET=change-me-32-bytes-minimum-secret-key-for-jwt-hs384

# ---------- 외부 통합 모드 (mock | live | off) ----------
SODAM_TOSS_MODE=mock
SODAM_FCM_MODE=mock
SODAM_SENTRY_MODE=off
SODAM_KAKAO_MODE=mock

# ---------- 카카오 OAuth (live 모드 시 필요) ----------
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ---------- 토스페이먼츠 (live 모드 시 필요) ----------
TOSS_CLIENT_KEY=test_ck_dev
TOSS_SECRET_KEY=test_sk_dev
TOSS_WEBHOOK_SECRET=change-me-webhook-secret

# ---------- FCM (live 모드 시 필요) ----------
FCM_PROJECT_ID=sodam-prod
# google-service-account.json 의 절대 경로 (volume 으로 마운트 권장)
FCM_CREDENTIALS_PATH=/app/secrets/fcm-service-account.json

# ---------- Sentry (live 모드 시 필요) ----------
SENTRY_DSN=
SENTRY_ENVIRONMENT=prod
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------- 채널톡 ----------
CHANNEL_TALK_PLUGIN_KEY=
