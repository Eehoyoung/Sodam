# =============================================================================
# Sodam monorepo root .gitignore
# Backend and frontend keep their own scoped ignore rules.
# This file only contains root-level common exclusions.
# =============================================================================

# Environment
.env
.env.local
.env.*
!.env.example

# IDE
.idea/
.vscode/
*.iml
.junie/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Repository exclusions
docs/
**/docs/
*.png
*.html
*.md
!/README.md
# 앱 빌드에 필요한 실제 에셋은 위 *.png 규칙에서 예외 처리 (로고/런처 아이콘 등)
!frontend/src/assets/**/*.png
!frontend/android/**/res/**/*.png
!frontend/ios/**/*.png

# Temporary scripts
_*.ps1
_*.py
_*.sh

# Logs
*.log
logs/
backend/.gradle-user-home/

# Backup / temporary files
*.bak
*.tmp
*.swp
.git.backup/

# graphify 지식 그래프 산출물 (로컬 생성물, 커밋 대상 아님)
graphify-out/
.graphify/

# 에뮬레이터 E2E 검증 산출물 (스크린샷/uiautomator 덤프) — 루트에 흩어지는 일회성 파일
/*.xml
e2e_*/

# 서명 완료 근로계약서 등 실 PII 원본 (.graphifyignore와 동일 대상 — git 추적도 금지)
backend/private-esign-objects/
