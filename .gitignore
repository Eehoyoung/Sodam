# =============================================================================
# Sodam monorepo root .gitignore
# Backend and frontend keep their own scoped ignore rules.
# This file only contains root-level common exclusions.
# =============================================================================

# Environment
.env
.env.local
.env.*
!.env.example

# IDE
.idea/
.vscode/
*.iml
.junie/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Repository exclusions
docs/
**/docs/
*.png
*.html
*.md
!/README.md
# 앱 빌드에 필요한 실제 에셋은 위 *.png 규칙에서 예외 처리 (로고/런처 아이콘 등)
!frontend/src/assets/**/*.png
!frontend/android/**/res/**/*.png
!frontend/ios/**/*.png

# Temporary scripts
_*.ps1
_*.py
_*.sh

# Logs
*.log
logs/
backend/.gradle-user-home/

# Backup / temporary files
*.bak
*.tmp
*.swp
.git.backup/
